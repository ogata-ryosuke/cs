---
import type { Project } from '@/lib/types';
import ProjectTable from './ProjectTable.astro';
import TechTagBadge from './TechTagBadge.astro';

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;

// Sort projects by ID in descending order (newest first)
const sortedProjects = [...projects].sort((a, b) => b.id - a.id);

// Define trending technologies priority order
const trendingTechs = ['TypeScript', 'React', 'Next.js', 'Python', 'FastAPI', 'Flutter', 'PostgreSQL', 'Go', 'AWS', 'Firebase', 'GraphQL', 'Kotlin', 'Vue.js'];

// Get all unique technologies, split into trending vs non-trending
const allTechsSet = new Set(sortedProjects.flatMap(p => p.technologies));
const trendingFiltered = trendingTechs.filter(t => allTechsSet.has(t));
const nonTrending = [...allTechsSet].filter(t => !trendingTechs.includes(t)).sort();
---

<div class="space-y-lg">
  {/* Filter bar */}
  <div class="bg-bg-surface border border-border-light rounded-card p-lg">
    <div class="flex items-center gap-sm mb-sm">
      <h3 class="text-subheading text-text-primary font-semibold">技術スタック</h3>
      <span class="text-small text-text-tertiary">
        <span id="filtered-count">{projects.length}</span> / {projects.length}
      </span>
    </div>

    <div id="tech-filters" class="flex gap-xs flex-wrap items-center">
      <button
        id="filter-all"
        class="inline-block px-sm py-xs rounded bg-tag-selected-bg text-tag-selected-text transition"
        data-filter="all"
      >
        すべて
      </button>
      {trendingFiltered.map(tech => (
        <button
          class="tech-filter inline-block px-sm py-xs rounded bg-tag-unselected-bg text-tag-unselected-text hover:bg-white border border-border-light transition"
          data-tech={tech}
        >
          {tech}
        </button>
      ))}
      {nonTrending.length > 0 && (
        <>
          <div id="tech-filters-collapsed" class="hidden flex gap-xs flex-wrap w-full">
            {nonTrending.map(tech => (
              <button
                class="tech-filter inline-block px-sm py-xs rounded bg-tag-unselected-bg text-tag-unselected-text hover:bg-white border border-border-light transition"
                data-tech={tech}
              >
                {tech}
              </button>
            ))}
          </div>
          <div class="w-full flex justify-center">
            <button
              id="tech-filter-toggle"
              class="inline-block px-sm py-xs rounded text-tag-unselected-text text-small hover:underline cursor-pointer"
              type="button"
            >
              +{nonTrending.length} more
            </button>
          </div>
        </>
      )}
    </div>
  </div>

  {/* Projects table */}
  <div class="flex justify-end mb-sm">
    <button
      id="toggle-all-details"
      class="inline-flex items-center gap-xs px-sm py-xs rounded text-small text-text-secondary hover:text-text-primary hover:underline cursor-pointer"
      type="button"
    >
      すべて開く
    </button>
  </div>
  <ProjectTable projects={sortedProjects} />
</div>

<script>
  // Expand/Collapse toggle for tech filter bar
  const filterToggle = document.getElementById('tech-filter-toggle');
  const filtersCollapsed = document.getElementById('tech-filters-collapsed');

  filterToggle?.addEventListener('click', () => {
    if (filtersCollapsed) {
      const isHidden = filtersCollapsed.classList.contains('hidden');
      if (isHidden) {
        filtersCollapsed.classList.remove('hidden');
        filterToggle.textContent = '- 折りたたむ';
      } else {
        filtersCollapsed.classList.add('hidden');
        const count = filtersCollapsed.querySelectorAll('.tech-filter').length;
        filterToggle.textContent = `+${count} more`;
      }
    }
  });

  // Filter logic
  const filterAll = document.getElementById('filter-all');
  const techFilters = document.querySelectorAll('.tech-filter');
  const projectRows = document.querySelectorAll('.project-row');
  const filteredCount = document.getElementById('filtered-count');

  let selectedTechs: Set<string> = new Set();

  function updateFilter() {
    let visibleCount = 0;

    projectRows.forEach((row: Element) => {
      const techs = (row.getAttribute('data-techs') || '').split(',').filter(Boolean);
      const isVisible =
        selectedTechs.size === 0 ||
        techs.some(tech => selectedTechs.has(tech));

      if (isVisible) {
        (row as HTMLElement).style.display = '';
        visibleCount++;
      } else {
        (row as HTMLElement).style.display = 'none';
      }
    });

    if (filteredCount) filteredCount.textContent = visibleCount.toString();
  }

  filterAll?.addEventListener('click', () => {
    selectedTechs.clear();
    techFilters.forEach((btn) => {
      btn.classList.remove('bg-tag-selected-bg', 'text-tag-selected-text');
      btn.classList.add('bg-tag-unselected-bg', 'text-tag-unselected-text');
    });
    filterAll?.classList.add('bg-tag-selected-bg', 'text-tag-selected-text');
    updateFilter();
  });

  techFilters.forEach((btn) => {
    btn.addEventListener('click', () => {
      const tech = btn.getAttribute('data-tech');
      if (!tech) return;

      if (selectedTechs.has(tech)) {
        selectedTechs.delete(tech);
        btn.classList.remove('bg-tag-selected-bg', 'text-tag-selected-text');
        btn.classList.add('bg-tag-unselected-bg', 'text-tag-unselected-text');
      } else {
        selectedTechs.add(tech);
        btn.classList.add('bg-tag-selected-bg', 'text-tag-selected-text');
        btn.classList.remove('bg-tag-unselected-bg', 'text-tag-unselected-text');
      }

      filterAll?.classList.remove('bg-tag-selected-bg', 'text-tag-selected-text');
      filterAll?.classList.add('bg-tag-unselected-bg', 'text-tag-unselected-text');
      updateFilter();
    });
  });
</script>
