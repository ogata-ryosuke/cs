---
import type { Project } from '@/lib/types';
import ProjectTable from './ProjectTable.astro';

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;

// Sort projects by ID in descending order (newest first)
const sortedProjects = [...projects].sort((a, b) => b.id - a.id);

// Technology category definitions
const langTags = ['Java', 'JavaScript', 'TypeScript', 'Python', 'PHP', 'Go', 'Ruby', 'Kotlin', 'C', 'C++', 'Objective-C', 'Perl', 'COBOL', 'Shell', 'PL/SQL', 'VBA', 'Visual Basic 6', 'Visual Basic .NET', 'Android Java', 'Action Script', 'CoffeeScript', 'HTML/CSS', 'HTML', 'CSS', 'BML', 'SASS'];
const dbInfraTags = ['MySQL', 'PostgreSQL', 'Oracle', 'SQLite', 'Access', 'DB2', 'HSQL', 'Redis', 'Elasticsearch', 'Firestore', 'MongoDB', 'Realm', 'WikipediaDB', 'AWS', 'AWS Batch', 'GCP', 'Firebase', 'Terraform', 'serverless', 'nginx', 'Ansible', 'Vagrant', 'DRBD', 'Heartbeat', 'PaceMaker', 'Logstash', 'Kibana', 'FileBeats', 'Docker', 'Net-LD', 'WireShark', 'i-Filter', 'Kaspersky', 'Juniper'];

const langSet = new Set(langTags);
const dbInfraSet = new Set(dbInfraTags);

// Trending (initial display) per category
const trendingLangs = ['TypeScript', 'Python', 'Go', 'Kotlin', 'Ruby', 'Java', 'JavaScript', 'PHP'];
const trendingFw = ['React', 'Flutter', 'Next.js', 'FastAPI', 'Vue.js', 'Spring', 'Laravel', 'Ruby on Rails'];
const trendingDbInfra = ['PostgreSQL', 'MySQL', 'AWS', 'GCP', 'Firebase', 'Redis', 'Elasticsearch', 'Terraform'];

// Collect all unique techs from projects
const allTechsSet = new Set(sortedProjects.flatMap(p => p.technologies));

// Categorize
function categorizeTechs(techSet: Set<string>, trending: string[]) {
  const trendingFiltered = trending.filter(t => techSet.has(t));
  const rest = [...techSet].filter(t => !trending.includes(t)).sort();
  return { trending: trendingFiltered, rest };
}

const allLangs = new Set([...allTechsSet].filter(t => langSet.has(t)));
const allDbInfra = new Set([...allTechsSet].filter(t => dbInfraSet.has(t)));
const allFw = new Set([...allTechsSet].filter(t => !langSet.has(t) && !dbInfraSet.has(t)));

const langs = categorizeTechs(allLangs, trendingLangs);
const fws = categorizeTechs(allFw, trendingFw);
const dbInfras = categorizeTechs(allDbInfra, trendingDbInfra);

const btnClass = "tech-filter inline-block px-sm py-xs rounded bg-tag-unselected-bg text-tag-unselected-text hover:bg-tag-selected-bg hover:text-tag-selected-text active:bg-tag-selected-bg active:text-tag-selected-text border border-border-light transition";
const labelClass = "text-small text-text-tertiary font-semibold whitespace-nowrap";
---

<div class="space-y-lg">
  {/* Filter bar */}
  <div class="bg-bg-surface border border-border-light rounded-card p-lg">
    <div class="flex items-center gap-sm mb-sm">
      <h3 class="text-subheading text-text-primary font-semibold">技術スタック</h3>
      <span class="text-small text-text-tertiary">
        <span id="filtered-count">{projects.length}</span> / {projects.length}
      </span>
      <button
        id="filter-all"
        class="inline-block px-sm py-xs rounded bg-tag-selected-bg text-tag-selected-text border border-tag-selected-bg transition"
        data-filter="all"
      >
        すべて
      </button>
    </div>

    <div id="tech-filters" class="space-y-sm">
      {/* 言語 */}
      <div class="flex gap-xs flex-wrap items-center" data-category="lang">
        <span class={labelClass}>言語</span>
        {langs.trending.map(tech => (
          <button class={btnClass} data-tech={tech}>{tech}</button>
        ))}
        {langs.rest.length > 0 && (
          <>
            <div class="tech-category-collapsed hidden flex gap-xs flex-wrap w-full pl-[40px]">
              {langs.rest.map(tech => (
                <button class={btnClass} data-tech={tech}>{tech}</button>
              ))}
            </div>
            <button class="tech-category-toggle inline-block px-sm py-xs rounded text-tag-unselected-text text-small hover:underline cursor-pointer" type="button">
              +{langs.rest.length} more
            </button>
          </>
        )}
      </div>

      {/* FW・ライブラリ */}
      <div class="flex gap-xs flex-wrap items-center" data-category="fw">
        <span class={labelClass}>FW・Lib</span>
        {fws.trending.map(tech => (
          <button class={btnClass} data-tech={tech}>{tech}</button>
        ))}
        {fws.rest.length > 0 && (
          <>
            <div class="tech-category-collapsed hidden flex gap-xs flex-wrap w-full pl-[52px]">
              {fws.rest.map(tech => (
                <button class={btnClass} data-tech={tech}>{tech}</button>
              ))}
            </div>
            <button class="tech-category-toggle inline-block px-sm py-xs rounded text-tag-unselected-text text-small hover:underline cursor-pointer" type="button">
              +{fws.rest.length} more
            </button>
          </>
        )}
      </div>

      {/* DB・インフラ */}
      <div class="flex gap-xs flex-wrap items-center" data-category="db-infra">
        <span class={labelClass}>DB・Infra</span>
        {dbInfras.trending.map(tech => (
          <button class={btnClass} data-tech={tech}>{tech}</button>
        ))}
        {dbInfras.rest.length > 0 && (
          <>
            <div class="tech-category-collapsed hidden flex gap-xs flex-wrap w-full pl-[60px]">
              {dbInfras.rest.map(tech => (
                <button class={btnClass} data-tech={tech}>{tech}</button>
              ))}
            </div>
            <button class="tech-category-toggle inline-block px-sm py-xs rounded text-tag-unselected-text text-small hover:underline cursor-pointer" type="button">
              +{dbInfras.rest.length} more
            </button>
          </>
        )}
      </div>
    </div>
  </div>

  {/* Projects table */}
  <div class="flex justify-end mb-sm">
    <button
      id="toggle-all-details"
      class="inline-flex items-center gap-xs px-sm py-xs rounded text-small text-text-secondary hover:text-text-primary hover:underline cursor-pointer"
      type="button"
    >
      すべて開く
    </button>
  </div>
  <ProjectTable projects={sortedProjects} />
</div>

<script>
  // Category expand/collapse toggles
  document.querySelectorAll('.tech-category-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const parent = btn.closest('[data-category]') || btn.parentElement;
      const collapsed = parent?.querySelector('.tech-category-collapsed');
      if (collapsed) {
        const isHidden = collapsed.classList.contains('hidden');
        if (isHidden) {
          collapsed.classList.remove('hidden');
          (btn as HTMLElement).textContent = '- 折りたたむ';
        } else {
          collapsed.classList.add('hidden');
          const count = collapsed.querySelectorAll('.tech-filter').length;
          (btn as HTMLElement).textContent = `+${count} more`;
        }
      }
    });
  });

  // Filter logic
  const filterAll = document.getElementById('filter-all');
  const techFilters = document.querySelectorAll('.tech-filter');
  const projectRows = document.querySelectorAll('.project-row');
  const filteredCount = document.getElementById('filtered-count');

  let selectedTechs: Set<string> = new Set();

  function updateFilter() {
    let visibleCount = 0;

    projectRows.forEach((row: Element) => {
      const techs = (row.getAttribute('data-techs') || '').split(',').filter(Boolean);
      const isVisible =
        selectedTechs.size === 0 ||
        techs.some(tech => selectedTechs.has(tech));

      if (isVisible) {
        (row as HTMLElement).style.display = '';
        visibleCount++;
      } else {
        (row as HTMLElement).style.display = 'none';
      }
    });

    if (filteredCount) filteredCount.textContent = visibleCount.toString();
  }

  filterAll?.addEventListener('click', () => {
    selectedTechs.clear();
    techFilters.forEach((btn) => {
      btn.classList.remove('bg-tag-selected-bg', 'text-tag-selected-text', 'border-tag-selected-bg');
      btn.classList.add('bg-tag-unselected-bg', 'text-tag-unselected-text', 'border-border-light');
    });
    filterAll?.classList.add('bg-tag-selected-bg', 'text-tag-selected-text', 'border-tag-selected-bg');
    filterAll?.classList.remove('bg-tag-unselected-bg', 'text-tag-unselected-text', 'border-border-light');
    updateFilter();
  });

  techFilters.forEach((btn) => {
    btn.addEventListener('click', () => {
      const tech = btn.getAttribute('data-tech');
      if (!tech) return;

      if (selectedTechs.has(tech)) {
        selectedTechs.delete(tech);
        btn.classList.remove('bg-tag-selected-bg', 'text-tag-selected-text', 'border-tag-selected-bg');
        btn.classList.add('bg-tag-unselected-bg', 'text-tag-unselected-text', 'border-border-light');
      } else {
        selectedTechs.add(tech);
        btn.classList.add('bg-tag-selected-bg', 'text-tag-selected-text', 'border-tag-selected-bg');
        btn.classList.remove('bg-tag-unselected-bg', 'text-tag-unselected-text', 'border-border-light');
      }

      filterAll?.classList.remove('bg-tag-selected-bg', 'text-tag-selected-text', 'border-tag-selected-bg');
      filterAll?.classList.add('bg-tag-unselected-bg', 'text-tag-unselected-text', 'border-border-light');
      updateFilter();
    });
  });
</script>
