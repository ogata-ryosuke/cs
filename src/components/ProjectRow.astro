---
import type { Project } from '@/lib/types';

interface Props {
  project: Project;
  index: number;
}

const { project, index } = Astro.props;
const [startYear, startMonth] = project.period.start.split('/').map(Number);
const [endYear, endMonth] = project.period.end ? project.period.end.split('/').map(Number) : [null, null];
const monthsCount = endYear
  ? (endYear - startYear) * 12 + (endMonth - startMonth + 1)
  : '進行中';

// Define trending technologies priority order
const trendingTechs = ['TypeScript', 'React', 'Next.js', 'Python', 'FastAPI', 'Flutter', 'PostgreSQL', 'Go', 'AWS', 'Firebase', 'GraphQL', 'Kotlin', 'Vue.js'];

// Sort technologies by trending priority
const sortedTechs = [
  ...project.technologies.filter(t => trendingTechs.includes(t)).sort((a, b) => trendingTechs.indexOf(a) - trendingTechs.indexOf(b)),
  ...project.technologies.filter(t => !trendingTechs.includes(t))
];

// Split text fields into list items
const descriptionItems = project.description?.split('\n').filter(Boolean) || [];
const learningItems = project.learning?.split('\n').filter(Boolean) || [];
const commentsItems = project.comments?.split('\n').filter(Boolean) || [];

const displayTechs = sortedTechs.slice(0, 4);
const collapsedTechs = sortedTechs.slice(4);
const hasMoreTechs = collapsedTechs.length > 0;
---

<tr class="hover:bg-bg-section transition project-row cursor-pointer" data-project-id={project.id} data-techs={project.technologies.join(',')}>
  <td class="px-lg py-md text-body text-text-secondary text-center">
    <svg class:list={['w-5 h-5 inline-block transform transition-transform chevron', `chevron-${project.id}`]} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="transform: rotate(0deg);">
      <polyline points="9 18 15 12 9 6"></polyline>
    </svg>
  </td>
  <td class="px-lg py-md text-body text-text-secondary">{index}</td>
  <td class="px-lg py-md text-body text-text-secondary whitespace-nowrap">
    {project.period.start}
    ~
    {project.period.end ?? '現在'}
  </td>
  <td class="px-lg py-md text-body text-text-secondary text-right whitespace-nowrap">{monthsCount}ヶ月</td>
  <td class="px-lg py-md text-body text-text-primary font-medium whitespace-nowrap">
    <div>{project.name}</div>
    <div class="flex gap-xs mt-xs">
      {project.contractType === '社員' && (
        <span class="inline-block px-xs py-0.5 rounded text-[10px] font-semibold bg-gray-100 text-gray-600 border border-gray-200">社員</span>
      )}
      {project.contractType === 'SES' && (
        <span class="inline-block px-xs py-0.5 rounded text-[10px] font-semibold bg-purple-100 text-purple-700 border border-purple-200">SES</span>
      )}
      {project.contractType === '受託' && (
        <span class="inline-block px-xs py-0.5 rounded text-[10px] font-semibold bg-green-100 text-green-700 border border-green-200">受託</span>
      )}
      {project.isLeader && (
        <span class="inline-block px-xs py-0.5 rounded text-[10px] font-semibold bg-blue-100 text-blue-700 border border-blue-200">リーダー</span>
      )}
    </div>
  </td>
  <td class="px-lg py-md text-body text-text-secondary">
    <div class="flex gap-xs flex-wrap items-center tech-container" data-tech-container={project.id}>
      {displayTechs.map(tech => (
        <span class="inline-block px-sm py-xs rounded bg-tag-unselected-bg text-tag-unselected-text text-small">
          {tech}
        </span>
      ))}
      {hasMoreTechs && (
        <>
          <span class="tech-collapsed hidden flex gap-xs flex-wrap" data-project-id={project.id}>
            {collapsedTechs.map(tech => (
              <span class="inline-block px-sm py-xs rounded bg-tag-unselected-bg text-tag-unselected-text text-small">
                {tech}
              </span>
            ))}
          </span>
          <button class="tech-expand-btn inline-block px-sm py-xs rounded text-tag-unselected-text text-small hover:underline cursor-pointer" data-project-id={project.id} type="button">
            +{collapsedTechs.length} more
          </button>
        </>
      )}
    </div>
  </td>
  <td class="px-lg py-md text-body text-text-secondary">{project.teamSize}人</td>
</tr>

{/* Expanded row (hidden by default, shown via JavaScript) */}
<tr class="project-detail hidden" data-project-id={project.id}>
  <td colspan="7" class="px-lg py-md bg-primary-50">
    <div class="space-y-sm">
      <div>
        <h4 class="text-subheading text-text-primary font-semibold mb-sm">担当業務</h4>
        <ul class="list-disc list-inside text-body text-text-secondary leading-relaxed space-y-1">
          {descriptionItems.map(item => <li>{item}</li>)}
        </ul>
      </div>
      {learningItems.length > 0 && (
        <div>
          <h4 class="text-subheading text-text-primary font-semibold mb-sm">業務で得た知見</h4>
          <ul class="list-disc list-inside text-body text-text-secondary leading-relaxed space-y-1">
            {learningItems.map(item => <li>{item}</li>)}
          </ul>
        </div>
      )}
      {commentsItems.length > 0 && (
        <div>
          <h4 class="text-subheading text-text-primary font-semibold mb-sm">コメント</h4>
          <ul class="list-disc list-inside text-body text-text-secondary leading-relaxed space-y-1">
            {commentsItems.map(item => <li>{item}</li>)}
          </ul>
        </div>
      )}
      <div>
        <h4 class="text-subheading text-text-primary font-semibold mb-sm">使用技術</h4>
        <div class="flex gap-xs flex-wrap">
          {sortedTechs.map(tech => (
            <span class="inline-block px-sm py-xs rounded bg-tag-unselected-bg text-tag-unselected-text text-small">
              {tech}
            </span>
          ))}
        </div>
      </div>
    </div>
  </td>
</tr>
