---
import type { Project } from '@/lib/types';

interface Props {
  project: Project;
  index: number;
}

const { project, index } = Astro.props;
const [startYear, startMonth] = project.period.start.split('/').map(Number);
const [endYear, endMonth] = project.period.end ? project.period.end.split('/').map(Number) : [null, null];
const monthsCount = endYear
  ? (endYear - startYear) * 12 + (endMonth - startMonth + 1)
  : '進行中';
---

<tr class="hover:bg-bg-section transition project-row cursor-pointer" data-project-id={project.id} data-techs={project.technologies.join(',')}>
  <td class="px-lg py-md text-body text-text-secondary text-center">
    <svg class:list={['w-5 h-5 inline-block transform transition-transform chevron', `chevron-${project.id}`]} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="transform: rotate(0deg);">
      <polyline points="9 18 15 12 9 6"></polyline>
    </svg>
  </td>
  <td class="px-lg py-md text-body text-text-secondary">{index}</td>
  <td class="px-lg py-md text-body text-text-secondary whitespace-nowrap">
    {project.period.start}
    ~
    {project.period.end ?? '現在'}
  </td>
  <td class="px-lg py-md text-body text-text-secondary text-right whitespace-nowrap">{monthsCount}ヶ月</td>
  <td class="px-lg py-md text-body text-text-primary font-medium whitespace-nowrap">{project.name}</td>
  <td class="px-lg py-md text-body text-text-secondary">
    <div class="flex gap-xs flex-wrap">
      {project.technologies.slice(0, 3).map(tech => (
        <span class="inline-block px-sm py-xs rounded bg-tag-unselected-bg text-tag-unselected-text text-small">
          {tech}
        </span>
      ))}
      {project.technologies.length > 3 && (
        <span class="text-small text-text-tertiary">+{project.technologies.length - 3}</span>
      )}
    </div>
  </td>
  <td class="px-lg py-md text-body text-text-secondary">{project.teamSize}</td>
</tr>

{/* Expanded row (hidden by default, shown via JavaScript) */}
<tr class="project-detail hidden" data-project-id={project.id}>
  <td colspan="7" class="px-lg py-md bg-primary-50">
    <div class="space-y-sm">
      <div>
        <h4 class="text-subheading text-text-primary font-semibold mb-sm">概要</h4>
        <p class="text-body text-text-secondary leading-relaxed">{project.description}</p>
      </div>
      <div>
        <h4 class="text-subheading text-text-primary font-semibold mb-sm">使用技術</h4>
        <div class="flex gap-xs flex-wrap">
          {project.technologies.map(tech => (
            <span class="inline-block px-sm py-xs rounded bg-tag-unselected-bg text-tag-unselected-text text-small">
              {tech}
            </span>
          ))}
        </div>
      </div>
    </div>
  </td>
</tr>
