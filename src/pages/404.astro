---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="ページが見つかりません | Career Sheet" description="お探しのページは見つかりませんでした。">
  <main class="min-h-screen flex items-center justify-center px-4">
    <div class="text-center space-y-lg">
      <p class="text-7xl font-bold text-primary-500">404</p>
      <h1 class="text-sectionHeading font-bold text-text-primary">ページが見つかりません</h1>
      <p class="text-body text-text-secondary">
        お探しのページは存在しないか、移動された可能性があります。
      </p>
      <a
        href="/"
        class="inline-block px-lg py-sm bg-primary-500 text-white rounded-card hover:bg-primary-600 transition-colors"
      >
        トップに戻る
      </a>
    </div>
  </main>
</Layout>
