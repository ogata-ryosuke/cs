---
import '../styles/globals.css';
import { careerData } from '@/lib/career-data-loader';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = '職務経歴書 | Career Sheet',
  description = 'Webエンジニアの職務経歴書。これまでの経歴、得意分野、技術スタック、案件実績をまとめたポートフォリオサイトです。',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/favicon.svg', Astro.site).href;

const dateModified = (() => {
  const match = careerData.updateDate.match(/(\d{4})年(\d{1,2})月/);
  if (!match) return new Date().toISOString().slice(0, 10);
  return `${match[1]}-${match[2].padStart(2, '0')}-01`;
})();

const allSkills = [
  ...careerData.skills.frontend,
  ...careerData.skills.backend,
  ...careerData.skills.infrastructure,
  ...careerData.skills.ai,
];

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "ProfilePage",
      "mainEntity": {
        "@id": `${Astro.site}#person`,
      },
      "url": canonicalURL,
      "name": title,
      "description": description,
      "inLanguage": "ja",
      "dateModified": dateModified,
    },
    {
      "@type": "Person",
      "@id": `${Astro.site}#person`,
      "name": careerData.profile.name ?? '',
      "jobTitle": "フルスタックエンジニア",
      "description": careerData.profile.bio,
      "url": canonicalURL,
      "sameAs": [
        careerData.profile.github,
      ],
      "knowsAbout": allSkills,
      "hasOccupation": {
        "@type": "Occupation",
        "name": "フルスタックエンジニア",
"skills": allSkills.join(", "),
      },
    },
    {
      "@type": "WebSite",
      "url": Astro.site?.toString(),
      "name": "職務経歴書 | Career Sheet",
      "description": description,
      "inLanguage": "ja",
      "author": {
        "@id": `${Astro.site}#person`,
      },
    },
  ],
};
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0EA5E9" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={title} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD Structured Data -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-71LZYCQY4J"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-71LZYCQY4J');
    </script>
  </head>
  <body class="bg-bg-page">
    <slot />
  </body>
</html>

<style is:global>
  html {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    color: #1f2937;
    background: #fafbfc;
  }
</style>
